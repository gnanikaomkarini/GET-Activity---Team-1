# OpenAI API Key (NOT NEEDED - using Puter.js with Claude)
# This is kept for reference only, not used in current implementation
# OPENAI_API_KEY=sk-your-api-key

# Database URL (optional, defaults to SQLite)
# DATABASE_URL=sqlite:///./energy_advisor.db

# Tariff rate per kWh (optional, defaults to 0.12)
# TARIFF_RATE=0.12
